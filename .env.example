# LINE Messaging API（LINE Developersコンソールで取得）
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# 薬剤師自身のLINE User ID（LINE Developersコンソールで確認可能）
PHARMACIST_LINE_USER_ID=your_line_user_id_here

# 患者さん向けの認証コード（かかりつけ患者さんにのみ伝える合言葉）
PATIENT_PASSCODE=your_passcode_here

# ホームページの記事管理ページ（/admin）用パスワード（任意。未設定でもLINEの
# 「管理者パスワード変更:新しいパスワード」でいつでも設定・変更できる）
ADMIN_PASSCODE=your_admin_passcode_here

# 薬剤師の電話番号（対応困難時にLINEから直接発信できるボタンに使用）
PHARMACIST_PHONE=090-1234-5678

# Anthropic API Key（https://console.anthropic.com で取得）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Redis接続文字列（認証状態・会話履歴などの永続化に使用）
REDIS_URL=your_redis_connection_string_here

# Cookie署名用のランダムな文字列（ホームページのセッション管理に使用）
SESSION_SECRET=your_random_secret_string_here

# 仕事の依頼フォームからのメール送信（任意。GmailのアプリパスワードでSMTP送信、未設定ならLINE通知のみ）
# ※Renderの無料プランはSMTP送信をブロックするため現状は未使用
EMAIL_USER=your_gmail_address_here
EMAIL_APP_PASSWORD=your_gmail_app_password_here
CONTACT_EMAIL_TO=your_destination_email_here

# サーバーポート（デフォルト3000）
PORT=3000

# 服薬リマインダー用の外部cronサービス認証トークン（任意の乱数文字列）
# 外部cronサービス（例: cron-job.org）から
# https://<ドメイン>/api/cron/medication-reminders?token=このトークンの値
# を15分間隔程度で呼び出すよう設定すると、患者ごとに設定した時刻に服薬リマインダーが届く
CRON_SECRET=your_random_cron_secret_here
